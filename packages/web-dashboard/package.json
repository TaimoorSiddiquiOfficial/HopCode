{
  "name": "@hoptrendy/web-dashboard",
  "version": "0.15.2",
  "description": "Standalone web dashboard for HopCode — session browser, chat viewer, cost tracking",
  "type": "module",
  "bin": {
    "hopcode-dashboard": "./dist/server/index.js"
  },
  "scripts": {
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build": "npm run build:client && npm run build:server",
    "start": "node dist/server/index.js",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit",
    "preview": "node dist/server/index.js"
  },
  "dependencies": {
    "@hoptrendy/webui": "*",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^9.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "hopcode",
    "dashboard",
    "web",
    "sessions"
  ],
  "author": "HopCode Team",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TaimoorSiddiquiOfficial/HopCode.git",
    "directory": "packages/web-dashboard"
  }
}
