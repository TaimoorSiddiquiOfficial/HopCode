{
  "name": "hopcode-vscode-ide-companion",
  "displayName": "HopCode Companion",
  "description": "Enable HopCode with direct access to your VS Code workspace.",
  "version": "0.19.5",
  "publisher": "hopcode",
  "icon": "assets/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/TaimoorSiddiquiOfficial/HopCode.git",
    "directory": "packages/vscode-ide-companion"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "license": "LICENSE",
  "preview": true,
  "categories": [
    "AI"
  ],
  "keywords": [
    "hopcode",
    "ai coding",
    "cli",
    "ide integration",
    "ide companion",
    "AI assistant"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "jsonValidation": [
      {
        "fileMatch": "**/.hopcode/settings.json",
        "url": "./schemas/settings.schema.json"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "hopcode-sidebar",
          "title": "HopCode",
          "icon": "assets/sidebar-icon.svg",
          "when": "!hopcode:supportsSecondarySidebar"
        }
      ],
      "secondarySidebar": [
        {
          "id": "hopcode-secondary",
          "title": "HopCode",
          "icon": "assets/sidebar-icon.svg",
          "when": "hopcode:supportsSecondarySidebar"
        }
      ]
    },
    "views": {
      "hopcode-sidebar": [
        {
          "type": "webview",
          "id": "hopcode.chatView.sidebar",
          "name": "HopCode",
          "icon": "assets/sidebar-icon.svg",
          "when": "!hopcode:supportsSecondarySidebar"
        }
      ],
      "hopcode-secondary": [
        {
          "type": "webview",
          "id": "hopcode.chatView.secondary",
          "name": "HopCode",
          "icon": "assets/sidebar-icon.svg",
          "when": "hopcode:supportsSecondarySidebar"
        }
      ]
    },
    "languages": [
      {
        "id": "hopcode-diff-editable"
      }
    ],
    "commands": [
      {
        "command": "hopcode.diff.accept",
        "title": "HopCode: Accept Current Diff",
        "icon": "$(check)"
      },
      {
        "command": "hopcode.diff.cancel",
        "title": "HopCode: Close Diff Editor",
        "icon": "$(close)"
      },
      {
        "command": "hopcode.runHopCode",
        "title": "HopCode: Run"
      },
      {
        "command": "hopcode.showNotices",
        "title": "HopCode: View Third-Party Notices"
      },
      {
        "command": "hopcode.openChat",
        "title": "HopCode: Open",
        "icon": "./assets/icon.png"
      },
      {
        "command": "hopcode.login",
        "title": "HopCode: Login"
      },
      {
        "command": "hopcode.focusChat",
        "title": "HopCode: Focus Chat View"
      },
      {
        "command": "hopcode.newConversation",
        "title": "HopCode: New Conversation"
      },
      {
        "command": "hopcode.showLogs",
        "title": "HopCode: Show Logs"
      },
      {
        "command": "hopcode.copyMessage",
        "title": "%hopcode.copyMessage.title%"
      },
      {
        "command": "hopcode.copyAllMessages",
        "title": "%hopcode.copyAllMessages.title%"
      },
      {
        "command": "hopcode.copyLastReply",
        "title": "%hopcode.copyLastReply.title%"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "hopcode.diff.accept",
          "when": "hopcode.diff.isVisible"
        },
        {
          "command": "hopcode.diff.cancel",
          "when": "hopcode.diff.isVisible"
        },
        {
          "command": "hopcode.login",
          "when": "false"
        },
        {
          "command": "hopcode.copyMessage",
          "when": "false"
        },
        {
          "command": "hopcode.copyAllMessages",
          "when": "false"
        },
        {
          "command": "hopcode.copyLastReply",
          "when": "false"
        }
      ],
      "webview/context": [
        {
          "command": "hopcode.copyMessage",
          "when": "webviewSection == 'chat-messages'",
          "group": "9_cutcopypaste@1"
        },
        {
          "command": "hopcode.copyAllMessages",
          "when": "webviewSection == 'chat-messages'",
          "group": "9_cutcopypaste@2"
        },
        {
          "command": "hopcode.copyLastReply",
          "when": "webviewSection == 'chat-messages'",
          "group": "9_cutcopypaste@3"
        }
      ],
      "editor/title": [
        {
          "command": "hopcode.diff.accept",
          "when": "hopcode.diff.isVisible",
          "group": "navigation"
        },
        {
          "command": "hopcode.diff.cancel",
          "when": "hopcode.diff.isVisible",
          "group": "navigation"
        },
        {
          "command": "hopcode.openChat",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "HopCode",
      "properties": {
        "hopcode.provider": {
          "order": 0,
          "type": "string",
          "enum": [
            "coding-plan",
            "api-key"
          ],
          "enumDescriptions": [
            "Alibaba Cloud Coding Plan — configurable from VS Code Settings",
            "Configured via HopCode: Auth or the onboarding button"
          ],
          "default": "coding-plan",
          "markdownDescription": "**Coding Plan**: enter API Key + Region here to sync `~/.hopcode/settings.json`.\n\n**API Key**: use **HopCode: Auth** or the onboarding button to configure ModelStudio or custom OpenAI-compatible providers."
        },
        "hopcode.apiKey": {
          "order": 1,
          "type": "string",
          "default": "",
          "markdownDescription": "API key used for **Coding Plan** settings sync. For **API Key** providers, configure the full provider details through **HopCode: Auth**."
        },
        "hopcode.codingPlanRegion": {
          "order": 2,
          "type": "string",
          "enum": [
            "china",
            "global"
          ],
          "enumDescriptions": [
            "China — 阿里云百炼 (aliyun.com)",
            "Global — Alibaba Cloud (alibabacloud.com)"
          ],
          "default": "china",
          "markdownDescription": "Region for Coding Plan. _(Only used when Provider is `coding-plan`)_"
        },
        "hopcode.dotIndicator": {
          "order": 3,
          "type": "boolean",
          "default": true,
          "description": "Show a colored dot on the tab icon when a task completes (orange) or needs your attention (blue) while the tab is hidden."
        },
        "hopcode.notifications": {
          "order": 4,
          "type": "boolean",
          "default": true,
          "description": "Show notifications with sound when a task completes (at least 20 seconds) or needs your attention, while you are not actively viewing the HopCode panel."
        }
      }
    },
    "keybindings": [
      {
        "command": "hopcode.diff.accept",
        "key": "ctrl+s",
        "when": "hopcode.diff.isVisible"
      },
      {
        "command": "hopcode.diff.accept",
        "key": "cmd+s",
        "when": "hopcode.diff.isVisible"
      },
      {
        "command": "hopcode.focusChat",
        "key": "ctrl+shift+l",
        "mac": "cmd+shift+l"
      }
    ]
  },
  "main": "./dist/extension.cjs",
  "type": "module",
  "scripts": {
    "prepackage": "node ./scripts/prepackage.js",
    "prebuild": "npm --prefix ../webui run build",
    "build": "node esbuild.js --production",
    "build:dev": "npm run check-types && npm run lint && node esbuild.js",
    "build:prod": "node esbuild.js --production",
    "generate:notices": "node ./scripts/generate-notices.js",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "watch": "npm-run-all2 -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npx --yes @vscode/vsce package --no-dependencies",
    "test": "vitest run",
    "test:ci": "vitest run --coverage",
    "validate:notices": "node ./scripts/validate-notices.js"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^20.19.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/semver": "^7.7.1",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.35.0",
    "@typescript-eslint/parser": "^8.35.0",
    "autoprefixer": "^10.4.22",
    "esbuild": "^0.25.12",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "npm-run-all2": "^8.0.4",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.8.2",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.14.1",
    "@hoptrendy/webui": "file:../webui",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cors": "^2.8.5",
    "express": "^4.22.1",
    "markdown-it": "^14.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "semver": "^7.7.4",
    "zod": "^3.25.76"
  }
}
