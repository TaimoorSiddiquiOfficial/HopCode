{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "baseUrl": ".",
    "lib": ["ES2023"],
    "composite": true,
    "types": ["node", "vitest/globals"],
    "paths": {
      "@hoptrendy/hopcode-core": ["../core/src/index.ts"],
      "@hoptrendy/hopcode-core/*": ["../core/src/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"],
  "references": [{ "path": "../core" }]
}
