    "@types/update-notifier": "^6.0.8",
    "ansi-regex": "^6.2.2",
    "command-exists": "^1.2.9",
    "comment-json": "^4.2.5",
    "diff": "^7.0.0",
    "dotenv": "^17.4.2",
    "fzf": "^0.5.2",
    "glob": "^11.1.0",
    "highlight.js": "^11.11.1",
    "ink": "^6.8.0",
    "ink-gradient": "^3.0.0",
    "ink-link": "^4.1.0",
    "ink-spinner": "^5.0.0",
