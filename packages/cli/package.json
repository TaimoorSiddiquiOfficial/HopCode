{
  "name": "@hoptrendy/hopcode-cli",
  "version": "0.18.1",
  "repository": {
    "url": "git+https://github.com/TaimoorSiddiquiOfficial/HopCode.git"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "hopcode": "dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "node ../../scripts/build_package.js",
    "start": "node dist/index.js",
    "debug": "node --inspect-brk dist/index.js",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:ci": "vitest run",
    "typecheck": "tsc --noEmit",
    "check-i18n": "tsx ../../scripts/check-i18n.ts"
  },
  "files": [
    "dist"
  ],
  "config": {
    "sandboxImageUri": "ghcr.io/hopcode/hopcode:0.18.1"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "latest",
    "@google/genai": "latest",
    "@iarna/toml": "latest",
    "@modelcontextprotocol/sdk": "latest",
    "@hoptrendy/channel-base": "file:../channels/base",
    "@hoptrendy/channel-discord": "file:../channels/discord",
    "@hoptrendy/channel-telegram": "file:../channels/telegram",
    "@hoptrendy/channel-weixin": "file:../channels/weixin",
    "@hoptrendy/channel-dingtalk": "file:../channels/dingtalk",
    "@hoptrendy/hopcode-core": "file:../core",
    "@hoptrendy/hopcode-server": "file:../server",
    "@hoptrendy/web-templates": "file:../web-templates",
    "@types/update-notifier": "latest",
    "ansi-regex": "latest",
    "command-exists": "latest",
    "comment-json": "latest",
    "diff": "latest",
    "dotenv": "latest",
    "fzf": "latest",
    "glob": "latest",
    "highlight.js": "latest",
    "ink": "latest",
    "ink-gradient": "latest",
    "ink-link": "latest",
    "ink-spinner": "latest",
    "lowlight": "latest",
    "open": "latest",
    "p-limit": "latest",
    "prompts": "latest",
    "react": "latest",
    "read-package-up": "latest",
    "shell-quote": "latest",
    "simple-git": "latest",
    "string-width": "latest",
    "strip-ansi": "latest",
    "strip-json-comments": "latest",
    "undici": "latest",
    "update-notifier": "latest",
    "wrap-ansi": "9.0.2",
    "yargs": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@babel/runtime": "latest",
    "@testing-library/react": "latest",
    "@types/archiver": "latest",
    "@types/command-exists": "latest",
    "@types/diff": "latest",
    "@types/dotenv": "latest",
    "@types/node": "latest",
    "@types/prompts": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@types/semver": "latest",
    "@types/shell-quote": "latest",
    "@types/yargs": "latest",
    "archiver": "latest",
    "ink-testing-library": "latest",
    "jsdom": "latest",
    "pretty-format": "latest",
    "react-dom": "latest",
    "typescript": "latest",
    "vitest": "latest"
  },
  "optionalDependencies": {
    "@teddyzhu/clipboard": "latest"
  },
  "engines": {
    "node": ">=20"
  }
}
